	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login (Get JWT Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"JWT Token saved: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login endpoint that returns a JWT token. The token is automatically saved to collection variables and used in subsequent requests."
					},
					"response": []
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "Get Products (Public - No Auth Required)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/products",
							"host": ["{{base_url}}"],
							"path": ["api", "products"]
						},
						"description": "Endpoint with @PermitAll - anyone can access without authentication. Returns list of products as DTOs."
					},
					"response": []
				},
				{
					"name": "Get Product by ID (Conditional Access)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/products/1",
							"host": ["{{base_url}}"],
							"path": ["api", "products", "1"]
						},
						"description": "@PreAuthorize with parameter check: allows ADMIN role OR when id == 1. Non-admin users can only access product with ID 1."
					},
					"response": []
				},
				{
					"name": "Create Product (ADMIN Only)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Gaming Laptop\",\n  \"description\": \"High-performance gaming laptop with RTX graphics\",\n  \"price\": 3499.99\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/products",
							"host": ["{{base_url}}"],
							"path": ["api", "products"]
						},
						"description": "@PreAuthorize('hasRole(ADMIN)') - Only admins can create products. Request uses validated DTO with constraints on name, description, and price."
					},
					"response": []
				},
				{
					"name": "Create Product (Invalid Data - Validation Test)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"X\",\n  \"description\": \"Too short name will trigger validation error\",\n  \"price\": -10.00\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/products",
							"host": ["{{base_url}}"],
							"path": ["api", "products"]
						},
						"description": "Tests validation constraints: name too short (min 2 chars), negative price. Should return 400 Bad Request with detailed validation errors."
					},
					"response": []
				},
				{
					"name": "Update Product (ADMIN - @Secured)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated Gaming Laptop Pro\",\n  \"description\": \"Updated description with new features\",\n  \"price\": 3299.99\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/products/1",
							"host": ["{{base_url}}"],
							"path": ["api", "products", "1"]
						},
						"description": "@Secured({'ROLE_ADMIN'}) - Classic Spring Security annotation. Only ADMIN role can update products."
					},
					"response": []
				},
				{
					"name": "Delete Product (ADMIN - @RolesAllowed)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/products/1",
							"host": ["{{base_url}}"],
							"path": ["api", "products", "1"]
						},
						"description": "@RolesAllowed({'ADMIN'}) - JSR-250 annotation. Only ADMIN can delete products. Audit log will record who deleted what."
					},
					"response": []
				},
				{
					"name": "PostAuthorize Example",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/products/post/1",
							"host": ["{{base_url}}"],
							"path": ["api", "products", "post", "1"]
						},
						"description": "@PostAuthorize('returnObject != null') - Evaluated after method execution. Can inspect returned value."
					},
					"response": []
				},
				{
					"name": "Forbidden Endpoint (@DenyAll)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/products/forbidden",
							"host": ["{{base_url}}"],
							"path": ["api", "products", "forbidden"]
						},
						"description": "@DenyAll - Always denied by method security. Should return 403 for any user."
					},
					"response": []
				}
			]
		},
