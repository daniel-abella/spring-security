{
	"info": {
		"_postman_id": "03296ed9-8a12-4130-9cf3-55347a59a9af",
		"name": "Spring Boot OWASP Top 10 - Enhanced Security",
		"description": "Collection updated with JWT authentication, DTOs with validation, audit logging, and enhanced security features.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
